# --- Connection Settings ---
JIRA_SERVER=https://jira.comp.<company_name>.com
JIRA_TOKEN=your_personal_access_token_here

# --- Extraction Logic ---
PROJECT_KEY=PROJ
PARENT_TYPE=Enhancement
CHILD_TYPE=Test
# Typically "Epic Link" for Data Center or "parent" for Cloud
LINK_FIELD=Epic Link

# --- Date Range (YYYY-MM-DD) ---
# Leave empty to extract everything up to today
START_DATE=2026-01-01
END_DATE=

# --- Field Mapping ---
# Find this ID using the IPython 'jira.fields()' test we did
STEPS_CUSTOM_FIELD=customfield_12345