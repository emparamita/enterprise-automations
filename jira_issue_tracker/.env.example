# --- Connection Settings ---
JIRA_SERVER=https://jira.comp.<company_name>.com
JIRA_TOKEN=your_personal_access_token_here

# --- Extraction Logic ---
PROJECT_KEY=PROJ
PARENT_TYPE=Enhancement
CHILD_TYPE=Test
LINK_FIELD=Epic Link

# --- Date Range ---
START_DATE=2026-01-01
END_DATE=

# --- Performance & Format ---
# Set to 'CSV' for massive historical runs, 'EXCEL' for formatted reports
EXPORT_FORMAT=EXCEL
API_BLOCK_SIZE=50
STEPS_CUSTOM_FIELD=customfield_12345