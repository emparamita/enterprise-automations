# --- Connection Settings ---
# --- Connection ---
JIRA_SERVER=https://jira.comp.<<company>>.com
JIRA_TOKEN=your_pat_token

# --- Hierarchy ---
PROJECT_KEY=PROJ
PARENT_TYPE=Enhancement
CHILD_TYPE=Test
LINK_FIELD=Epic Link

# --- Logging Configuration ---
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG
LOG_TO_FILE=True
LOG_FILE_NAME=jira_extractor.log

# --- Performance & Format ---
EXPORT_FORMAT=EXCEL
API_BLOCK_SIZE=50