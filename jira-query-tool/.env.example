# --- Connection ---
JIRA_SERVER=https://jira.comp.<company_name>.com
JIRA_TOKEN=your_personal_access_token

# --- Execution ---
# Any valid JQL string
JIRA_QUERY=project = "PROJ" AND status = "Closed" AND resolution = "Fixed"

# --- Performance ---
API_BLOCK_SIZE=50
# Fields to extract (comma-separated)
EXTRACT_FIELDS=key,summary,status,created,priority,assignee